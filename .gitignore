# Local directory for Terraform
.terraform/

# Terraform lock file (optional to ignore, but standard for monorepo development if not locking provider versions)
.terraform.lock.hcl

# State files
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Crash log files
crash.log

# Variables files (sensitive credentials)
*.tfvars
*.tfvars.json

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI Config
.terraformrc
terraform.rc
